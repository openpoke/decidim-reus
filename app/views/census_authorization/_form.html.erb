<div class="form__wrapper" data-partial-demo>
  <%= form.text_field :document_number %>

  <%= form.date_select :date_of_birth, start_year: 1900, end_year: 14.years.ago.year, default: 35.years.ago, prompt: { day: t(".date_select.day"), month: t(".date_select.month"), year: t(".date_select.year") } %>

  <% if form.object.phone_number? && params[:controller] == "decidim/verifications/authorizations" %>
    <%= form.text_field :telephone_number_custom, help_text: t("decidim.devise.registrations.new.telephone_number_custom_help") %>
  <% end %>

  <%= form.hidden_field :handler_name %>
  <%= form.hidden_field :controller, value: params[:controller] %>
</div>
